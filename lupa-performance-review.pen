                          "type": "text",
                          "id": "DtPpO",
                          "fill": "$--body",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Everything we do comes back to three values. They're not posters on a wall — they're how we make decisions when no one is watching.",
