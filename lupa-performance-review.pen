                          "type": "text",
                          "id": "HvVOY",
                          "fill": "$--body",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "See what needs doing and do it. Bring a recommendation, not just a problem, and close the loop on what you start.",
