                          "fontFamily": "$--font-primary",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HOQf1",
                          "fill": "$--foreground",
                          "content": "1. Customer trust",
                          "lineHeight": 1.4,
                          "fontFamily": "$--font-primary",
                          "fontSize": 16,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "x82azp",
                          "fill": "$--body",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "We're reliable and honest, so customers feel safe depending on us. That means doing what we say, protecting their data, and owning our mistakes openly.",
